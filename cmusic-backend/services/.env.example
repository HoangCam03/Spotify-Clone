# ===== GATEWAY =====
GATEWAY_PORT=3000
NODE_ENV=development

# ===== SERVICES PORTS =====
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CATALOG_SERVICE_PORT=3003
PLAYLIST_SERVICE_PORT=3004
LIKES_SERVICE_PORT=3005
HISTORY_SERVICE_PORT=3006
SEARCH_SERVICE_PORT=3007
ADMIN_SERVICE_PORT=3008

# ===== SERVICE URLS =====
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CATALOG_SERVICE_URL=http://localhost:3003
PLAYLIST_SERVICE_URL=http://localhost:3004
LIKES_SERVICE_URL=http://localhost:3005
HISTORY_SERVICE_URL=http://localhost:3006
SEARCH_SERVICE_URL=http://localhost:3007
ADMIN_SERVICE_URL=http://localhost:3008

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/spotify

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_change_in_production
REFRESH_TOKEN_EXPIRE=30d

# ===== CLOUDINARY =====
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== CORS =====
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
